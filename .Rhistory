# 加载必要包
library(tidyverse)
# 示例数据生成（假设100名患者，15个证型得分）
set.seed(123)
patient_data <- data.frame(
# 心虚损维度
心气虚证 = sample(0:48, 100, replace = TRUE),
心阴虚证 = sample(0:43, 100, replace = TRUE),
心阳虚证 = sample(0:52, 100, replace = TRUE),
心血虚证 = sample(0:47, 100, replace = TRUE),
# 脾虚损维度
脾气虚证 = sample(0:39, 100, replace = TRUE),
脾阳虚证 = sample(0:43, 100, replace = TRUE),
# 肝虚损维度
肝阴虚证 = sample(0:40, 100, replace = TRUE),
肝血虚证 = sample(0:42, 100, replace = TRUE),
# 肺虚损维度
肺气虚证 = sample(0:41, 100, replace = TRUE),
肺阴虚证 = sample(0:59, 100, replace = TRUE),
肺阳虚证 = sample(0:48, 100, replace = TRUE),
# 肾虚损维度
肾气虚证 = sample(0:39, 100, replace = TRUE),
肾阴虚证 = sample(0:43, 100, replace = TRUE),
肾阳虚证 = sample(0:66, 100, replace = TRUE),
肾精虚证 = sample(0:35, 100, replace = TRUE)
)
# 标准化加权综合评分法
weight_vector <- c(0.07, 0.06, 0.08, 0.05,  # 心系权重
0.04, 0.03,  # 脾系
0.04, 0.03,  # 肝系
0.05, 0.06, 0.04,  # 肺系
0.04, 0.05, 0.07, 0.03) # 肾系
# 计算标准化得分
normalized_scores <- patient_data %>%
mutate(across(everything(), ~ ./c(48,43,52,47,  # 心系满分
39,43,  # 脾系
40,42,  # 肝系
41,59,48,  # 肺系
39,43,66,35)))  # 肾系
# 计算综合得分
patient_data$综合得分 <- as.matrix(normalized_scores) %*% weight_vector
# 主成分分析（PCA）
pca_result <- prcomp(patient_data[,1:15], scale. = TRUE)
summary(pca_result)
# 提取前3个主成分
pca_scores <- predict(pca_result)[,1:3]
# 潜在类别分析（LCA）需要安装poLCA包
# install.packages("poLCA")
library(poLCA)
install.packages("poLCA")
