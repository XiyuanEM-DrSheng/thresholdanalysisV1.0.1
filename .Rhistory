-0.5*time_treat +            # 时间×治疗负交互
0.2*gender_treat +           # 性别×治疗正交互
-0.1*bp +                    # 血压负效应
u_id,                        # 增强随机效应
# 生成二分类结局（添加概率校准）
prob = plogis(logit_p),
outcome = rbinom(total_obs, 1, prob)
)
# 验证分布并诊断
cat("全数据集分布:\n0:", sum(data$outcome==0),
"\n1:", sum(data$outcome==1),
"\n平衡比例:", round(mean(data$outcome), 2), "\n")
# 添加分布均衡性验证
dist_check <- function(data) {
tab <- table(data$outcome)
cat("\n分布诊断:\n0比例:", round(prop.table(tab)[1],3),
"\n1比例:", round(prop.table(tab)[2],3),
"\n基尼系数:", ineq(data$outcome, "Gini") %>% round(3),
"\n熵值:", entropy(tab) %>% round(3))
}
dist_check(data)
library(lme4)
library(tidyverse)
library(caret)  # 添加平衡验证工具
set.seed(123)
# 基础参数重置
n_id <- 100
n_time <- 5
total_obs <- n_id * n_time
# 生成基础数据框
data <- expand.grid(
id = 1:n_id,
time = 1:n_time
)
# 关键调整1：重构协变量生成逻辑
data <- data %>%
mutate(
# 时间变量（保留中心化）
time_c = time - mean(time),
# 性别变量（调整比例）
gender = factor(rbinom(n_id, 1, 0.6) %>% rep(each=n_time)),  # 提高男性比例
# 年龄变量（限制范围）
age_baseline = pmin(65, pmax(35, rnorm(n_id, mean=50, sd=5))) %>% rep(each=n_time),
age = age_baseline + 0.2*time_c,
# 血压变量（增加方差）
bp = 110 + 0.4*age_baseline - 2*as.numeric(gender) +
6*time_c + rnorm(total_obs, sd=8),  # 增加时间效应和随机波动
# 治疗组分配（调整随机化）
treatment = factor(rbinom(n_id, 1, 0.7) %>% rep(each=n_time)),  # 提高治疗组比例
# 关键调整2：增强随机效应（三倍方差）
u_id = rep(rnorm(n_id, sd=2.5), each=n_time),  # 大幅增加个体差异
# 交互项（保留结构）
time_treat = time_c * as.numeric(treatment),
gender_treat = as.numeric(gender) * as.numeric(treatment)
)
# 关键调整3：完全重构logit函数
data <- data %>%
mutate(
# 新参数体系（基于临床参考值）
logit_p = -4.0 +  # 大幅降低基础概率
0.2*time_c +                 # 温和时间效应
-0.3*as.numeric(gender) +    # 性别负效应（男性保护作用）
0.02*age +                   # 温和年龄效应
1.5*as.numeric(treatment) +  # 强化治疗效应
-0.5*time_treat +            # 时间×治疗负交互
0.2*gender_treat +           # 性别×治疗正交互
-0.1*bp +                    # 血压负效应
u_id,                        # 增强随机效应
# 生成二分类结局（添加概率校准）
prob = plogis(logit_p),
outcome = rbinom(total_obs, 1, prob)
)
# 验证分布并诊断
cat("全数据集分布:\n0:", sum(data$outcome==0),
"\n1:", sum(data$outcome==1),
"\n平衡比例:", round(mean(data$outcome), 2), "\n")
# 添加分布均衡性验证
dist_check <- function(data) {
tab <- table(data$outcome)
cat("\n分布诊断:\n0比例:", round(prop.table(tab)[1],3),
"\n1比例:", round(prop.table(tab)[2],3),
"\n基尼系数:", ineq(data$outcome, "Gini") %>% round(3),
"\n熵值:", entropy(tab) %>% round(3))
}
dist_check(data)
