# 定义需要检测的单细胞测序相关R包列表
packages_needed <- c("Seurat", "SingleCellExperiment", "monocle", "scran", "Ragas")
# 检测包是否已安装，并自动安装缺失的包
for (pkg in packages_needed) {
if (!(pkg %in% installed.packages()[, "Package"])) {
# 尝试从CRAN安装
install.packages(pkg, dependencies = TRUE)
# 若CRAN安装失败，可尝试从Bioconductor安装（适用于部分生物信息学包）
if (!(pkg %in% installed.packages()[, "Package"])) {
if (!requireNamespace("BiocManager", quietly = TRUE)) {
install.packages("BiocManager")
}
BiocManager::install(pkg)
}
# 若仍失败，可添加GitHub安装逻辑（需devtools包）
if (!(pkg %in% installed.packages()[, "Package"])) {
if (!requireNamespace("devtools", quietly = TRUE)) {
install.packages("devtools")
}
# 示例：从GitHub安装Ragas包（需替换为实际仓库地址）
if (pkg == "Ragas") {
devtools::install_github("jig4003/Ragas", upgrade = "never")
}
}
}
# 加载包以验证安装成功
library(pkg, character.only = TRUE)
cat(paste("包", pkg, "已成功加载。\n"))
}
