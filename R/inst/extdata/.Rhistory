setwd("C:/Users/74736/Desktop/packagebuilding/thresholdanalysis")
install.packages("thresholdanalysis_1.0.0.tar.gz", repos = NULL, type = "source")
library(thresholdanalysis)
library(readxl)
setwd("C:\\Users\\74736\\Desktop\\packagebuilding\\thresholdanalysis\\R\\inst\\extdata")
data<- read_excel("CRRTstudy_1144patients_revised.xlsx")
data<-na.omit(data)
result_cox <- cox_threshold(
Surv(time_to_death_28D, Death_28D) ~ Age+Sex,
data = data,
rcs_nodes = 4,
var_name = "Age"
)
result_logistic <- logistic_threshold(
Death_28D ~ SOFA+Age,
data = data,
rcs_nodes = 4,
var_name = "SOFA"
)
