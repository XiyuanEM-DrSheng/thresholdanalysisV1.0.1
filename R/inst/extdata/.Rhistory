library(readxl)
setwd("C:\\74736\\Desktop\\\\thresholdanalysis\\R\\inst\\extdata")
setwd("C:\\Users\\74736\\Desktop\\\\thresholdanalysis\\R\\inst\\extdata")
data<- read_excel("CRRTstudy_1144patients_revised.xlsx")
data<-na.omit(data)
result_cox <- cox_threshold(
Surv(time_to_death_28D, Death_28D) ~ SBP + Age + Sex,
data = data,
rcs_nodes = 4,
var_name = "SBP"
)
result_logistic <- logistic_threshold(
Death_28D ~ SBP + Age + Sex,
data = data,
rcs_nodes = 4,
var_name = "SBP"
)
result_linear <- linear_threshold(
K ~ SBP + Age + Sex,
data = data,
var_name = "SBP"
)
